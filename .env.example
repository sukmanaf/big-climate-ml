# Koneksi PostGIS — salin ke .env lalu sesuaikan ke server yang dipakai
# Contoh: DATABASE_URL=postgresql+psycopg2://user:pass@host:port/dbname
DATABASE_URL=postgresql+psycopg2://user:climate@localhost:5432/climate_etl

# Reproducibility
RANDOM_SEED=42

# MLflow (file backend lokal untuk PoC)
MLFLOW_TRACKING_URI=file:./mlruns

# Direktori artefak model
MODEL_DIR=./models
